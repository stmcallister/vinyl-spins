# Backend
PORT=8080

# Discogs OAuth 1.0a app credentials (create an app at https://www.discogs.com/settings/developers)
DISCOGS_CONSUMER_KEY=
DISCOGS_CONSUMER_SECRET=
DISCOGS_OAUTH_CALLBACK_URL=http://localhost:8081/auth/discogs/callback

# Required by Discogs API policy. If unset, a sensible default is used.
DISCOGS_USER_AGENT=vinyl-spin-tracker/0.1 (local)

# 32-byte base64 key recommended (used for AES-GCM encryption at rest)
# Example generation:
#   openssl rand -base64 32
APP_ENC_KEY=

# Database (used by the Go backend)
DATABASE_URL=postgres://discogs:discogs@127.0.0.1:5433/discogs_listen_tracker?sslmode=disable

# Frontend
VITE_API_URL=http://localhost:8081

# Where to send the browser after successful OAuth.
FRONTEND_URL=http://localhost:5174/

# Set to 1 if you're behind HTTPS and want Secure cookies.
COOKIE_SECURE=0
